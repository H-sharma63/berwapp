{
  "name": "berwapp",
  "version": "0.1.1",
  "description": "TUI-based CLI scaffolding tool for modern web projects with AI agent config generation",
  "type": "module",
  "bin": {
    "berwapp": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest"
  },
  "keywords": [
    "cli",
    "scaffold",
    "nextjs",
    "tui",
    "boilerplate",
    "ai-agent"
  ],
  "author": "Harshit",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "templates"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "handlebars": "^4.7.9",
    "ink": "^7.0.6",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "ora": "^9.4.0",
    "react": "^19.2.7",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/update-notifier": "^6.0.8",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
